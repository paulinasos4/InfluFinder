# PostgreSQL (Neon, Railway, etc.)
# Neon: copiá "Connection string" con usuario y contraseña; agregá ?sslmode=require si hace falta
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# Opcional: subida de fotos en Vercel (Storage → Blob)
# BLOB_READ_WRITE_TOKEN=

# Correos (Resend): https://resend.com/api-keys
# La clave conviene ponerla en .env.local (no en git). Copiá .env.local.example → .env.local
# Sin RESEND_API_KEY el registro y la aprobación funcionan igual; no se envían mails.
# RESEND_API_KEY=re_xxxx
# Remitente: onboarding@resend.dev sirve para pruebas pero suele ir a spam.
# Para producción: en Resend → Domains, verificá tu dominio, agregá DNS SPF/DKIM, y usá:
# EMAIL_FROM=Influ Finder <noreply@tudominio.com>
# Misma marca de dominio en respuestas (opcional, ayuda a la reputación):
# EMAIL_REPLY_TO=soporte@tudominio.com
# URL en links del mail: SITE_URL, NEXT_PUBLIC_SITE_URL o NEXT_PUBLIC_APP_URL
# SITE_URL=https://tu-dominio.com
